generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntryCategory {
  Study
  Finance
  Health
  Personal
}

model Entry {
  id         String        @id @default(uuid()) @db.Uuid
  userId     String
  title      String
  value      Float
  metricType String        @default("time")
  category   EntryCategory
  date       DateTime
  note       String        @default("")
  foodName   String?
  portionGrams Float?
  proteinGrams Float?
  carbsGrams Float?
  fatGrams   Float?
  foodSource String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([userId])
  @@index([userId, metricType])
  @@index([userId, date(sort: Desc)])
  @@index([date(sort: Desc)])
  @@index([category])
}
