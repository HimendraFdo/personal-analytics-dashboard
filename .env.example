# Runtime app role connection string. In production this can be the pooled Neon
# URL, but the role must not own app tables and must not have BYPASSRLS.
DATABASE_URL="postgresql://APP_USER:PASSWORD@HOST-pooler/DATABASE?sslmode=require"
# Migration/admin role connection string for applying Prisma migrations.
# Prefer a direct, non-pooler Neon URL for schema changes.
DIRECT_DATABASE_URL="postgresql://MIGRATION_USER:PASSWORD@HOST/DATABASE?sslmode=require"

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_or_pk_live_placeholder"
CLERK_SECRET_KEY="sk_test_or_sk_live_placeholder"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL="/dashboard"
# Optional. The app disables Clerk telemetry automatically outside production;
# set this to "true" to disable it explicitly in every environment.
# NEXT_PUBLIC_CLERK_TELEMETRY_DISABLED="true"
# Optional exact Clerk Frontend API URL for CSP when it cannot be derived from the publishable key.
# CLERK_FRONTEND_API_URL="https://your-instance.clerk.accounts.dev"

APP_ORIGIN="http://localhost:3000"
# Optional comma-separated allowlist for additional deployed or preview origins.
# APP_ALLOWED_ORIGINS="http://localhost:3000,https://your-domain.example"

UPSTASH_REDIS_REST_URL="https://example.upstash.io"
UPSTASH_REDIS_REST_TOKEN="placeholder"

OPENAI_API_KEY=""

# Optional. Free USDA FoodData Central API key for high-quality generic food
# data in food search (sign up at https://fdc.nal.usda.gov/api-key-signup).
# Without it, food search uses Open Food Facts only.
# USDA_FDC_API_KEY=""
# Optional. Two-letter country code (e.g. "nz") to prioritise Open Food Facts
# products sold in that country instead of the worldwide database.
# OPENFOODFACTS_COUNTRY="nz"
MONEY_IMPORT_MAX_FILE_MB=10
# Optional local/dev-only deterministic extraction fixture for manual QA.
# MONEY_IMPORT_EXTRACT_FIXTURE_PATH="lib/money-import/fixtures/synthetic-bank-statement.json"
